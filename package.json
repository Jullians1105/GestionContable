{
  "name": "gestor-tareas-oficina",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start": "concurrently \"npm --prefix backend run dev\" \"npm run dev\"",
    "start:legacy": "concurrently \"npm --prefix mcpServer run dev\" \"npm --prefix backend start\"",
    "backend:install": "npm --prefix backend install",
    "backend:migrate": "npm --prefix backend run migrate",
    "backend:migrate:seed": "npm --prefix backend run migrate:seed",
    "backend:test": "npm --prefix backend test",
    "e2e": "cypress open",
    "e2e:run": "cypress run",
    "stop": "node -e \"process.platform === 'win32' ? require('child_process').execSync('taskkill /F /IM node.exe') : require('child_process').execSync('pkill -f node');\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "date-fns": "^3.3.1",
    "jspdf": "^4.2.1",
    "react": "^18.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "socket.io-client": "^4.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.0",
    "cypress": "^13.17.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0"
  }
}
