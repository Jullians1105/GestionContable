# ===========================
# Gestcon - Variables para docker-compose
# Copia este archivo como .env y completa los valores
# ===========================

# App
PORT=3000
# En producción puedes poner múltiples orígenes separados por coma
# CLIENT_URL=https://gestcon.work,https://192.168.1.12
CLIENT_URL=http://localhost:5173

# PostgreSQL
DB_PORT=5432
DB_NAME=gestcon
DB_USER=postgres
DB_PASSWORD=cambia_esto_por_un_password_seguro
DB_TEST_NAME=gestcon_test

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=otro_secreto_diferente_muy_largo_y_aleatorio
JWT_REFRESH_EXPIRES_IN=7d

# n8n — Automatización de workflows
# Genera con: openssl rand -hex 32
N8N_ENCRYPTION_KEY=cambia_esto_por_una_clave_hex_de_32_bytes
