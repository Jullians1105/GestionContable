# ===========================
# TaskFlow Pro - Variables de Entorno
# Copia este archivo como .env y completa los valores
# ===========================

# App
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskflow
DB_USER=postgres
DB_PASSWORD=tu_password_seguro
DB_TEST_NAME=taskflow_test

# O usar URL completa (tiene prioridad sobre variables individuales)
# DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/taskflow

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio_en_produccion
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=otro_secreto_diferente_muy_largo_y_aleatorio
JWT_REFRESH_EXPIRES_IN=7d

# Emails (opcional - SendGrid)
# SENDGRID_API_KEY=SG.xxxx
# FROM_EMAIL=noreply@taskflow.com

# SMTP (recuperación de contraseña). En desarrollo con docker-compose usar Mailhog:
# SMTP_HOST=mailhog
# SMTP_PORT=1025
# Sin SMTP_USER/SMTP_PASS para Mailhog. Para un proveedor real (Gmail, Resend, etc.)
# completar host/puerto/usuario/contraseña y SMTP_SECURE=true si aplica.
SMTP_HOST=
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@taskflow.local

# Devuelve el token de recuperación directamente en la respuesta del API,
# para no depender de revisar un correo en desarrollo. NUNCA activar en producción.
SHOW_RESET_TOKEN=false

# Slack (opcional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Logs
# LOG_LEVEL=debug
